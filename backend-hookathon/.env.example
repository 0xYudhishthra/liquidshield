# ============================================
# AQUA0 BACKEND ENVIRONMENT VARIABLES
# ============================================

# Server
PORT=3001
NODE_ENV=development

# ============================================
# AUTHENTICATION
# ============================================
# Basic Auth for all routes except /health, /ready
API_BASIC_AUTH_USER=admin
API_BASIC_AUTH_PASSWORD=admin

# API Key required for /api/v1/* routes (X-API-Key header)
API_KEY=your-api-key

# ============================================
# SUPABASE (Application Data)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ============================================
# PONDER (Indexed On-Chain Data)
# Shared between API (read) and Ponder Indexer (write)
# ============================================
PONDER_DATABASE_URL=postgresql://postgres:password@localhost:5432/ponder

# ============================================
# PONDER INDEXER RPC ENDPOINTS
# Used by packages/ponder-indexer only
# ============================================
PONDER_RPC_BASE=https://mainnet.base.org
PONDER_RPC_UNICHAIN=https://unichain.calderachain.xyz/http

# ============================================
# REDIS (Caching)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# BLOCKCHAIN RPC (API direct reads)
# Used by packages/api for on-chain reads via viem
# One per supported chain
# ============================================
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_UNICHAIN=https://unichain.calderachain.xyz/http

# ============================================
# CROSS-CHAIN (LayerZero/Stargate)
# ============================================
LAYERZERO_ENDPOINT_BASE=0x1a44076050125825900e736c501f859c50fE728c
LAYERZERO_ENDPOINT_UNICHAIN=0x1a44076050125825900e736c501f859c50fE728c

# ============================================
# REBALANCER
# ============================================
REBALANCER_PRIVATE_KEY=0x...
